# Database (matches docker-compose.yml postgres service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/renderical

# better-auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Additional trusted origins for auth (comma-separated; BETTER_AUTH_URL is always trusted)
TRUSTED_ORIGINS=

# Google OAuth (social sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI (AI chat features via @ai-sdk/openai)
OPENAI_API_KEY=

# SMTP (defaults match docker-compose.yml mailpit service)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
